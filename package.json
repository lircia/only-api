{
  "name": "api-relay-cloudflare",
  "version": "0.1.0",
  "private": true,
  "description": "Cloudflare Workers + Pages API relay with users, API keys, channel management, usage stats, and notifications.",
  "scripts": {
    "dev:api": "wrangler dev apps/api/src/index.ts --name api-relay-worker --compatibility-date 2024-12-01",
    "dev:web": "vite --host 127.0.0.1 apps/web",
    "build:web": "vite build apps/web",
    "deploy:api": "wrangler deploy apps/api/src/index.ts --name api-relay-worker --compatibility-date 2024-12-01 --keep-vars",
    "deploy:web": "npm run build:web && wrangler pages deploy apps/web/dist --project-name api-relay-console",
    "db:migrate:local": "wrangler d1 migrations apply api_relay --local --migrations-dir=apps/api/migrations",
    "db:migrate:remote": "wrangler d1 migrations apply api_relay --remote --migrations-dir=apps/api/migrations",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.0.7"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260708.1",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "typescript": "^5.7.2",
    "wrangler": "^4.108.0"
  }
}
